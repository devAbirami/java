Using sliding window and 2 pointers

class Solution {
  public int longestSubarray(int[] arr, int k) {
    int left = 0, right = 0, sum = 0, max = 0;
    while (right < arr.length) {
    sum = sum + arr[right];
    while (sum > k) {
        sum = sum - arr[left++]; //shrinking from left
    }
    if (sum == k) max = Math.max(max, right - left + 1); // replace with length of the current windown
    right++; //expanding to the right
    }
    return max;
  }
}
